@prefix dct: <http://purl.org/dc/terms/> .
@prefix ebv: <https://maytetoscano.github.io/bblock-ebv-bioclima/vocab/#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ebv:pci_method_v1 a prov:Plan,
        ebv:IndicatorComputationMethod ;
    dct:title [ ] ;
    ebv:baselinePeriod [ ebv:endYear 2010 ;
            ebv:startYear 2001 ] ;
    ebv:components ebv:changepoint_pvalue,
        ebv:changepoint_year,
        ebv:phenological_anomaly,
        ebv:phenological_trend ;
    ebv:inputObservedProperty "ebv:vap_doy" ;
    ebv:outputIndicator "ebv:PhenologicalChangeIndicator" ;
    ebv:recentPeriod [ ebv:endYear 2018 ;
            ebv:startYear 2011 ] .

ebv:changepoint_pvalue ebv:algorithm "ebv:PettittTestPValue" ;
    ebv:unit "1" .

ebv:changepoint_year ebv:algorithm "ebv:PettittTest" ;
    ebv:unit "year" .

ebv:phenological_anomaly ebv:algorithm "ebv:BaselineDifference" ;
    ebv:unit "days" .

ebv:phenological_trend ebv:algorithm "ebv:TheilSenSlope" ;
    ebv:unit "days/year" .

